root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Windows-specific files that should remain CRLF
[*.{ps1,bat}]
end_of_line = crlf

[*.{js,ts,html,css,md,txt}]
trim_trailing_whitespace = false

[*.cs]
dotnet_sort_system_directives_first = true
indent_style = space
indent_size = 4
csharp_new_line_before_open_brace = all

[*.{cpp,h,hpp,c}]
indent_style = space
indent_size = 4
c_brace_style = k&r

[*.proto]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2
