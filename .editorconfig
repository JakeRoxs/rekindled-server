root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Windows-specific files that should remain CRLF
[*.{ps1,bat}]
end_of_line = crlf

[*.{js,ts,html,css,md,txt}]
trim_trailing_whitespace = false

[*.cs]
dotnet_sort_system_directives_first = true
indent_style = space
indent_size = 2
# sort using directives
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
# var usage preferences (from external)
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
# expression-bodied members
csharp_style_expression_bodied_methods = false:suggestion
csharp_style_expression_bodied_properties = false:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_operators = false:suggestion
csharp_style_expression_bodied_accessors = false:suggestion
# braces: use same-line by default within repo
csharp_new_line_before_open_brace_types = none:silent
csharp_new_line_before_open_brace_methods = none:silent
csharp_new_line_before_open_brace_properties = none:silent
csharp_new_line_before_open_brace_accessors = none:silent
csharp_new_line_before_open_brace_anonymous_methods = none:silent
csharp_new_line_before_open_brace_control_blocks = none:silent
csharp_new_line_before_open_brace_anonymous_types = none:silent
csharp_new_line_before_open_brace_lambdas = none:silent
# naming rules for private fields
dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.accessibility = private

dotnet_naming_style.camel_case_underscore.capitalization = camel_case
dotnet_naming_style.camel_case_underscore.required_prefix = _
# require braces
csharp_prefer_braces = true:suggestion
# prefer explicit tuple names
csharp_style_tuple_names = true:suggestion

[*.{cpp,h,hpp,c}]
indent_style = space
indent_size = 4
c_brace_style = k&r

[*.proto]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2
