<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta
            name="description"
            content="DSOS Master Server status dashboard for Dark Souls Open Server. Monitor active servers and health in real-time."
        />
        <meta property="og:title" content="DSOS Master Server" />
        <meta
            property="og:description"
            content="Live status and server listing for the DSOS Master Server."
        />
        <meta property="og:type" content="website" />
        <title>DSOS Master Server</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --bg: linear-gradient(
                    180deg,
                    #0b1220 0%,
                    #111826 46%,
                    #0e1324 100%
                );
                --surface: #111a2c;
                --surface-alt: #16213c;
                --text: #e8f2ff;
                --muted: #a8b6d2;
                --accent: #69c0ff;
                --accent-2: #8dd4ff;
                --border: rgba(255, 255, 255, 0.12);
                --line: #24324d;
                --radius: 14px;
                --shadow: 0 18px 36px rgba(0, 0, 10, 0.45);
                --max-width: 1200px;
                --focus: #5dc5ff;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                margin: 0;
                min-height: 100vh;
                background: var(--bg);
                color: var(--text);
                font-family:
                    "Outfit",
                    ui-sans-serif,
                    system-ui,
                    -apple-system,
                    BlinkMacSystemFont,
                    "Segoe UI",
                    sans-serif;
                line-height: 1.55;
            }

            .skip-link {
                position: absolute;
                top: -40px;
                left: 16px;
                background: rgba(17, 33, 59, 0.95);
                color: #e5f2ff;
                padding: 8px 12px;
                border-radius: 8px;
                z-index: 99;
                font-size: 14px;
                text-decoration: none;
                transition: top 160ms ease;
            }

            .skip-link:focus {
                top: 16px;
                outline: 2px solid var(--focus);
                outline-offset: 4px;
            }

            header {
                padding: 44px 24px 16px;
                text-align: left;
                max-width: var(--max-width);
                margin: auto;
            }

            h1 {
                margin: 0;
                font-size: clamp(2rem, 5vw, 3.2rem);
                font-weight: 700;
                letter-spacing: -0.03em;
            }

            .subtitle {
                margin: 8px 0 0;
                color: var(--muted);
                font-size: 1rem;
                max-width: 760px;
            }

            .page {
                max-width: var(--max-width);
                margin: auto;
                padding: 12px 20px 40px;
            }

            .top-panel {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 1rem;
                margin-top: 20px;
            }

            .panel {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                padding: 20px;
                display: flex;
                flex-direction: column;
                gap: 10px;
                transition:
                    transform 220ms ease,
                    box-shadow 220ms ease,
                    border-color 220ms ease;
            }

            .panel:hover {
                transform: translateY(-2px);
                border-color: rgba(105, 192, 255, 0.6);
            }

            .panel h2 {
                margin: 0;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: var(--muted);
            }

            .panel .metric {
                font-size: clamp(1.8rem, 4vw, 2.8rem);
                font-weight: 700;
                margin: 0;
            }

            .panel small {
                color: var(--muted);
            }

            .meta {
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
                margin: 24px 0 0;
                color: var(--muted);
                font-size: 0.92rem;
            }

            .meta a {
                color: var(--accent);
                text-decoration: none;
                font-weight: 600;
            }

            .meta a:hover,
            .meta a:focus-visible {
                text-decoration: underline;
            }

            .theme-toggle {
                position: fixed;
                top: 22px;
                right: 22px;
                border-radius: 999px;
                border: 1px solid rgba(255, 255, 255, 0.18);
                background: rgba(7, 13, 25, 0.8);
                color: var(--text);
                padding: 10px 14px;
                font-size: 1rem;
                cursor: pointer;
                backdrop-filter: blur(9px);
                z-index: 100;
            }

            .theme-toggle:hover {
                transform: translateY(-1px);
            }

            .status-line {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                font-size: 0.9rem;
                border-radius: 999px;
                padding: 8px 12px;
                border: 1px dashed rgba(255, 255, 255, 0.25);
                background: rgba(255, 255, 255, 0.04);
                color: var(--text);
            }

            .status-line.error {
                border-color: rgba(255, 97, 89, 0.6);
                background: rgba(255, 97, 89, 0.16);
                color: #ffd1cf;
            }

            .server-list {
                margin-top: 28px;
                border: 1px solid var(--border);
                background: var(--surface);
                border-radius: var(--radius);
                overflow: hidden;
                box-shadow: var(--shadow);
            }

            .server-list header {
                padding: 14px 18px;
                border-bottom: 1px solid var(--line);
                background: rgba(10, 18, 35, 0.22);
                color: var(--muted);
                font-weight: 600;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            thead th {
                text-align: left;
                font-size: 0.8rem;
                color: var(--muted);
                padding: 12px 14px;
                border-bottom: 1px solid var(--line);
                text-transform: uppercase;
                letter-spacing: 0.12em;
            }

            tbody tr {
                border-bottom: 1px solid var(--line);
                transition: background 180ms ease;
            }

            tbody tr:hover {
                background: rgba(105, 192, 255, 0.11);
            }

            tbody td {
                padding: 11px 14px;
                font-size: 0.91rem;
                color: #e9efff;
                vertical-align: middle;
            }

            .status-pill {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 999px;
                padding: 3px 10px;
                font-size: 0.76rem;
                font-weight: 600;
                color: #f4f9ff;
                background: rgba(34, 144, 235, 0.2);
                border: 1px solid rgba(34, 144, 235, 0.4);
            }

            .status-pill.shard {
                background: rgba(201, 121, 255, 0.2);
                border-color: rgba(201, 121, 255, 0.38);
            }

            .empty-state {
                padding: 30px 18px;
                text-align: center;
                color: var(--muted);
                background: rgba(255, 255, 255, 0.03);
                border-top: 1px solid var(--line);
            }

            .light {
                --bg: linear-gradient(
                    180deg,
                    #f8fbff 0%,
                    #f3f7ff 40%,
                    #edf4ff 100%
                );
                --surface: #fff;
                --surface-alt: #f6f9ff;
                --text: #102a46;
                --muted: #4f637f;
                --border: rgba(15, 31, 58, 0.12);
                --line: #dfe9f5;
                --shadow: 0 12px 22px rgba(4, 18, 44, 0.2);
                --focus: #2f7be0;
            }

            .light .theme-toggle {
                background: rgba(255, 255, 255, 0.9);
                color: var(--text);
                border-color: rgba(89, 105, 150, 0.21);
            }
        </style>
    </head>
    <body>
        <a href="#dashboard" class="skip-link">Skip to dashboard</a>
        <button
            id="themeToggle"
            class="theme-toggle"
            type="button"
            aria-label="Toggle light/dark theme"
        >
            <span id="themeToggleIcon" aria-hidden="true">🌙</span>
        </button>

        <header>
            <h1>DSOS Master Server</h1>
            <p class="subtitle">
                Live status, health checks, and active server listing for the
                DSOS network.
            </p>
        </header>

        <main id="dashboard" class="page">
            <section class="top-panel" aria-label="Master Server metrics">
                <article class="panel">
                    <h2>Active servers</h2>
                    <p class="metric" id="activeCount">
                        <%= status.activeServerCount %>
                    </p>
                    <small id="refreshInfo"></small>
                </article>
                <article class="panel">
                    <h2>Master uptime</h2>
                    <p class="metric" id="uptime"><%= uptime %></p>
                    <small>Process uptime since service start</small>
                </article>
                <article class="panel" aria-labelledby="oldestVersionLabel" aria-describedby="oldestVersionDesc">
                    <h2 id="oldestVersionLabel">Oldest version</h2>
                    <p class="metric" id="oldestVersionValue"><%= status.oldestSupportedVersion %></p>
                    <small id="oldestVersionDesc">Minimum client version accepted</small>
                </article>
            </section>

            <section
                class="meta"
                id="statusMeta"
                aria-live="polite"
                aria-atomic="true"
            >
                <span class="status-line" id="pollStatus">Status: ready</span>
                <span class="status-line" id="allowedShardStatus"
                    >Shards allowlist: <%=
                    Array.isArray(status.shardingAllowList) &&
                    status.shardingAllowList.length ?
                    status.shardingAllowList.join(', ') : 'none' %></span
                >
                <span class="status-line" id="filtersStatus"
                    >Filters: <%= Array.isArray(status.filters) &&
                    status.filters.length ? status.filters.join(', ') : 'none'
                    %></span
                >
                <span class="status-line" id="censorsStatus"
                    >Censors: <%= Array.isArray(status.censors) &&
                    status.censors.length ? status.censors.join(', ') : 'none'
                    %></span
                >
                <a
                    href="/api/v1/servers"
                    target="_blank"
                    rel="noopener noreferrer"
                    >Raw JSON /api/v1/servers</a
                >
            </section>

            <section class="server-list" aria-label="Active server list">
                <header>Active servers</header>
                <div id="serverLoading" class="empty-state">
                    Loading server list…
                </div>
                <table
                    id="serversTable"
                    hidden
                    aria-label="Server table overview"
                >
                    <thead>
                        <tr>
                            <th>Host</th>
                            <th>Description</th>
                            <th>Players</th>
                            <th>Mode</th>
                            <th>Shard</th>
                        </tr>
                    </thead>
                    <tbody id="serversBody"></tbody>
                </table>
                <div id="serversEmpty" class="empty-state" hidden>
                    No active servers at the moment. Add a server and it will
                    appear here.
                </div>
            </section>
        </main>

        <script type="application/json" id="dashboard-config">
            <%= JSON.stringify({ pollIntervalMs }) %>
        </script>
        <script>
            const THEME_KEY = "dsos:master-theme";
            const themeButton = document.getElementById("themeToggle");
            const themeIcon = document.getElementById("themeToggleIcon");
            const getTheme = () => localStorage.getItem(THEME_KEY) || "dark";

            const setTheme = (theme) => {
                document.documentElement.classList.toggle(
                    "light",
                    theme === "light",
                );
                themeIcon.textContent = theme === "light" ? "☀️" : "🌙";
                themeButton.setAttribute(
                    "aria-label",
                    theme === "light"
                        ? "Switch to dark theme"
                        : "Switch to light theme",
                );
                localStorage.setItem(THEME_KEY, theme);
            };

            themeButton.addEventListener("click", () =>
                setTheme(getTheme() === "light" ? "dark" : "light"),
            );
            setTheme(getTheme());

            const POLL_INTERVAL_MS = (() => {
                const raw =
                    document.getElementById("dashboard-config")?.textContent;
                if (!raw) return 15000;
                try {
                    return JSON.parse(raw).pollIntervalMs || 15000;
                } catch {
                    return 15000;
                }
            })();

            const setText = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.textContent = value;
            };

            const setStatus = (message, type = "normal") => {
                const status = document.getElementById("pollStatus");
                if (!status) return;
                status.textContent = `Status: ${message}`;
                status.className =
                    type === "error" ? "status-line error" : "status-line";
            };

            const updateServerInfo = (meta) => {
                const shards =
                    Array.isArray(meta?.shardingAllowList) &&
                    meta.shardingAllowList.length
                        ? meta.shardingAllowList.join(", ")
                        : "none";
                const filters =
                    Array.isArray(meta?.filters) && meta.filters.length
                        ? meta.filters.join(", ")
                        : "none";
                const censors =
                    Array.isArray(meta?.censors) && meta.censors.length
                        ? meta.censors.join(", ")
                        : "none";

                setText("allowedShardStatus", `Shards allowlist: ${shards}`);
                setText("filtersStatus", `Filters: ${filters}`);
                setText("censorsStatus", `Censors: ${censors}`);
            };

            const safeString = (value, fallback = "") =>
                value != null && value !== "" ? String(value) : fallback;

            const renderRows = (servers) => {
                const table = document.getElementById("serversTable");
                const body = document.getElementById("serversBody");
                const empty = document.getElementById("serversEmpty");
                const loader = document.getElementById("serverLoading");

                if (!body || !table || !empty || !loader) return;
                body.innerHTML = "";

                if (!Array.isArray(servers)) {
                    table.hidden = true;
                    empty.hidden = true;
                    loader.hidden = false;
                    loader.textContent = "Server data unavailable";
                    return;
                }

                if (servers.length === 0) {
                    table.hidden = true;
                    empty.hidden = false;
                    loader.hidden = true;
                    return;
                }

                table.hidden = false;
                empty.hidden = true;
                loader.hidden = true;

                servers.forEach((s) => {
                    const row = document.createElement("tr");

                    const hostCell = document.createElement("td");
                    const hostname = safeString(s.Hostname, "Unknown");
                    hostCell.title = hostname;

                    if (s.WebAddress && typeof s.WebAddress === "string") {
                        try {
                            const candidate = new URL(s.WebAddress);
                            if (
                                candidate.protocol === "http:" ||
                                candidate.protocol === "https:"
                            ) {
                                const link = document.createElement("a");
                                link.href = candidate.toString();
                                link.target = "_blank";
                                link.rel = "noopener noreferrer";
                                link.style.color = "var(--accent)";
                                link.textContent = hostname;
                                hostCell.appendChild(link);
                            } else {
                                hostCell.textContent = hostname;
                            }
                        } catch {
                            hostCell.textContent = hostname;
                        }
                    } else {
                        hostCell.textContent = hostname;
                    }

                    const descCell = document.createElement("td");
                    const description = safeString(s.Description, "No description");
                    descCell.title = description;
                    descCell.textContent = description;

                    const playerCell = document.createElement("td");
                    playerCell.textContent = String(
                        Number.isInteger(s.PlayerCount)
                            ? s.PlayerCount
                            : Number(s.PlayerCount) || 0,
                    );

                    const modeCell = document.createElement("td");
                    modeCell.textContent = safeString(s.GameType, "Classic");

                    const shardCell = document.createElement("td");
                    const shardSpan = document.createElement("span");
                    shardSpan.className = `status-pill ${s.IsShard ? "shard" : ""}`;
                    shardSpan.textContent = s.IsShard ? "shard" : "main";
                    shardCell.appendChild(shardSpan);

                    row.appendChild(hostCell);
                    row.appendChild(descCell);
                    row.appendChild(playerCell);
                    row.appendChild(modeCell);
                    row.appendChild(shardCell);
                    body.appendChild(row);
                });
            };

            const fetchStatus = async () => {
                try {
                    const res = await fetch("/api/v1/servers/status", {
                        cache: "no-store",
                    });
                    if (!res.ok) throw new Error("status fetch failed");
                    const json = await res.json();
                    if (json.status !== "success")
                        throw new Error("status payload invalid");

                    setText("activeCount", json.statusData.activeServerCount);
                    setText("uptime", json.statusData.uptime);
                    updateServerInfo(json.statusData);
                    setStatus(`Live (${new Date().toLocaleTimeString()})`);
                } catch (error) {
                    console.warn("Status update error", error);
                    setStatus("Error fetching status", "error");
                }
            };

            const fetchServers = async () => {
                const loader = document.getElementById("serverLoading");
                if (loader) {
                    loader.hidden = false;
                    loader.textContent = "Loading server list…";
                }

                try {
                    const res = await fetch("/api/v1/servers", {
                        cache: "no-store",
                    });
                    if (!res.ok) throw new Error("server fetch failed");
                    const json = await res.json();
                    if (json.status !== "success")
                        throw new Error("server payload invalid");

                    renderRows(json.servers);
                    setStatus(
                        `Server list updated (${new Date().toLocaleTimeString()})`,
                    );
                } catch (error) {
                    console.warn("Server list error", error);
                    renderRows([]);
                    setStatus("Error fetching servers", "error");
                }
            };

            const refresh = async () => {
                await Promise.all([fetchStatus(), fetchServers()]);
            };

            refresh();
            let refreshInterval = setInterval(refresh, POLL_INTERVAL_MS);

            document.addEventListener("visibilitychange", () => {
                if (document.hidden) {
                    clearInterval(refreshInterval);
                } else {
                    refresh();
                    refreshInterval = setInterval(refresh, POLL_INTERVAL_MS);
                }
            });
        </script>
    </body>
</html>
