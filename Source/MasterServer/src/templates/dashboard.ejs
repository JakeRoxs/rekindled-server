<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<title>DSOS Master Server</title>
	<style>
		:root {
			--bg: radial-gradient(circle at top, rgba(255,108,61,0.22) 0%, transparent 45%),
				linear-gradient(195deg, rgba(7, 10, 18, 1) 0%, rgba(14, 18, 34, 1) 55%, rgba(5, 8, 16, 1) 100%);
			--card: rgba(255, 255, 255, 0.08);
			--card-border: rgba(255, 255, 255, 0.12);
			--text: #e6edf7;
			--muted: rgba(230, 237, 247, 0.72);
			--accent: #ff6c3d;
			--accent-2: #55c2ff;
			--shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
			--radius: 18px;
			--max: 980px;
		}

		.light {
			--bg: radial-gradient(circle at top, rgba(255, 255, 255, 0.6) 0%, transparent 45%),
				linear-gradient(195deg, rgba(248, 250, 255, 1) 0%, rgba(240, 243, 255, 1) 55%, rgba(245, 247, 255, 1) 100%);
			--card: rgba(12, 16, 24, 0.06);
			--card-border: rgba(20, 26, 38, 0.14);
			--text: #0f172a;
			--muted: rgba(15, 23, 42, 0.64);
			--accent: #d84315;
			--accent-2: #1d4ed8;
			--shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
		}

		* { box-sizing: border-box; }
		body {
			margin: 0;
			min-height: 100vh;
			background: var(--bg);
			color: var(--text);
			font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		}

		header {
			padding: 60px 24px 36px;
			text-align: center;
			position: relative;
		}

		h1 {
			font-size: clamp(2.4rem, 5vw, 3.6rem);
			letter-spacing: -0.04em;
			margin: 0;
		}

		.subtitle {
			margin: 8px auto 0;
			max-width: 750px;
			font-size: 1.05rem;
			color: var(--muted);
			line-height: 1.5;
		}

		main {
			max-width: var(--max);
			margin: 0 auto 48px;
			padding: 0 24px 32px;
		}

		.stats {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			gap: 20px;
			margin-top: 28px;
		}

		.card {
			background: var(--card);
			border: 1px solid var(--card-border);
			border-radius: var(--radius);
			backdrop-filter: blur(14px);
			box-shadow: var(--shadow);
			padding: 22px 24px;
			position: relative;
			overflow: hidden;
			transition: transform 220ms ease, box-shadow 220ms ease;
		}

		.card:hover {
			transform: translateY(-2px);
			box-shadow: 0 32px 78px rgba(0, 0, 0, 0.5);
		}

		.card::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background: radial-gradient(circle at top left, rgba(255, 108, 61, 0.4), transparent 55%);
			opacity: 0.28;
			pointer-events: none;
		}

		.card > * {
			position: relative;
		}

		.label {
			font-size: 0.85rem;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: var(--muted);
			margin: 0;
		}

		.value {
			font-size: clamp(2.1rem, 4vw, 3.8rem);
			font-weight: 700;
			margin: 8px 0 0;
			line-height: 1.04;
		}

		small {
			display: block;
			font-size: 0.85rem;
			color: var(--muted);
			margin-top: 14px;
		}

		.meta {
			display: flex;
			gap: 10px;
			flex-wrap: wrap;
			margin-top: 28px;
			font-size: 0.9rem;
			color: rgba(230, 237, 247, 0.62);
		}

		.meta a {
			color: var(--accent);
			text-decoration: none;
			font-weight: 600;
		}

		.meta a:hover {
			text-decoration: underline;
		}

		.theme-toggle {
			position: absolute;
			top: 22px;
			right: 22px;
			border: 1px solid rgba(255, 255, 255, 0.16);
			background: rgba(0, 0, 0, 0.18);
			color: var(--text);
			padding: 10px 14px;
			border-radius: 999px;
			font-size: 1.05rem;
			cursor: pointer;
			backdrop-filter: blur(10px);
			transition: transform 160ms ease, background 160ms ease;
		}

		.sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}

		.theme-toggle:hover {
			transform: translateY(-1px);
			background: rgba(255, 255, 255, 0.22);
		}

		.light .theme-toggle {
			background: rgba(255, 255, 255, 0.24);
			color: var(--text);
			border: 1px solid rgba(15, 23, 42, 0.18);
		}

		.badge {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 6px 12px;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.08);
			border: 1px solid rgba(255, 255, 255, 0.14);
		}

		.badge::before {
			content: '';
			display: inline-block;
			width: 10px;
			height: 10px;
			border-radius: 999px;
			background: linear-gradient(135deg, var(--accent), var(--accent-2));
			animation: pulse 1.8s ease-in-out infinite;
		}

		@keyframes pulse {
			0%, 100% { transform: scale(1); opacity: 0.75; }
			50% { transform: scale(1.35); opacity: 1; }
		}
	</style>
</head>
<body>
	<header>
		<h1>DSOS Master Server</h1>
		<p class="subtitle">Master server status dashboard</p>
		<button id="themeToggle" class="theme-toggle" type="button" aria-label="Toggle light/dark theme">
			<span class="sr-only">Toggle light/dark theme</span>
			<span id="themeToggleIcon" aria-hidden="true">🌙</span>
		</button>
	</header>

	<main>
		<div class="stats">
			<article class="card">
				<p class="label">Active servers</p>
				<p class="value" id="activeCount"><%= status.activeServerCount %></p>
				<small id="refreshInfo"></small>
			</article>

			<article class="card">
				<p class="label">Uptime</p>
				<p class="value" id="uptime"><%= uptime %></p>
				<small>Since process start</small>
			</article>
		</div>

		<div class="meta" aria-live="polite" aria-atomic="true">
			<span class="badge" id="badgeAllowlist">Sharding allowlist: <%= status.shardingAllowList %></span>
			<span class="badge" id="badgeFilters">Filters: <%= status.filters %></span>
			<span class="badge" id="badgeCensors">Censors: <%= status.censors %></span>
			<a href="/api/v1/servers">View raw JSON /api/v1/servers</a>
			<span class="badge" id="pollStatus" style="background: rgba(255, 255, 255, 0.06);">Polling...</span>
		</div>
	</main>
	<script type="application/json" id="dashboard-config"><%= JSON.stringify({ pollIntervalMs }) %></script>
	<script>
		const THEME_KEY = 'ds3os:theme';
		const button = document.getElementById('themeToggle');
		const getTheme = () => localStorage.getItem(THEME_KEY) || 'dark';
		const setTheme = (theme) => {
			document.documentElement.classList.toggle('light', theme === 'light');
			const icon = document.getElementById('themeToggleIcon');
			if (icon) icon.textContent = theme === 'light' ? '☀️' : '🌙';
			if (button) button.setAttribute('aria-label', theme === 'light' ? 'Switch to dark theme' : 'Switch to light theme');
			localStorage.setItem(THEME_KEY, theme);
		};

		if (button) {
			button.addEventListener('click', () => {
				setTheme(getTheme() === 'light' ? 'dark' : 'light');
			});
		}

		const POLL_INTERVAL_MS = (() => {
			const raw = document.getElementById('dashboard-config')?.textContent;
			if (!raw) return 15000;
			try {
				return JSON.parse(raw).pollIntervalMs;
			} catch {
				return 15000;
			}
		})();

		const setTextIfExists = (id, text) => {
			const el = document.getElementById(id);
			if (el) el.textContent = text;
		};

		const setPollStatus = (message, isError = false) => {
			const el = document.getElementById('pollStatus');
			if (!el) return;
			el.textContent = message;
			el.style.background = isError ? 'rgba(255, 72, 66, 0.2)' : 'rgba(255, 255, 255, 0.06)';
		};

		const renderBadge = (id, label, value) => {
			const el = document.getElementById(id);
			if (!el) return;
			if (!value || (Array.isArray(value) && value.length === 0)) {
				el.style.display = 'none';
				return;
			}
			el.style.display = '';
			if (Array.isArray(value)) value = value.join(', ');
			el.textContent = `${label}: ${value}`;
		};

		const updateStats = (data) => {
			setTextIfExists('activeCount', data.activeServerCount);
			setTextIfExists('uptime', data.uptime);
			renderBadge('badgeAllowlist', 'Sharding allowlist', data.shardingAllowList);
			renderBadge('badgeFilters', 'Filters', data.filters);
			renderBadge('badgeCensors', 'Censors', data.censors);
		};

		const updateRefreshInfo = () => {
			const el = document.getElementById('refreshInfo');
			if (!el) return;
			el.textContent = `Refreshed every ${Math.round(POLL_INTERVAL_MS / 1000)} seconds`;
		};

		let pollTimer = null;

		const startPolling = () => {
			if (pollTimer) return;
			pollTimer = setInterval(poll, POLL_INTERVAL_MS);
		};

		const stopPolling = () => {
			if (!pollTimer) return;
			clearInterval(pollTimer);
			pollTimer = null;
		};

		const poll = async () => {
			try {
				const res = await fetch('/api/v1/servers/status', { cache: 'no-store' });
				if (!res.ok) throw new Error('Fetch failed');
				const json = await res.json();
				if (json.status === 'success') {
					updateStats(json.statusData);
					setPollStatus(`Last updated ${new Date().toLocaleTimeString()}`);
					updateRefreshInfo();
				} else {
					setPollStatus('Polling error', true);
				}
			} catch (err) {
				setPollStatus('Polling failed', true);
				console.warn('Dashboard polling failed', err);
			}
		};

		const onVisibilityChange = () => {
			if (document.hidden) {
				stopPolling();
			} else {
				poll();
				startPolling();
			}
		};

		setTheme(getTheme());
		updateRefreshInfo();
		poll();
		startPolling();
		document.addEventListener('visibilitychange', onVisibilityChange);
	</script>
</body>
</html>
